# Project Settings
Example environment variables for the Email Filter Backend.
Do NOT commit the actual .env file.

APP_NAME=Email Filter API
ENV=development
DEBUG=True
API_VERSION=v1
HOST=0.0.0.0
PORT=8000

# Google/Gmail OAuth configuration.
# This stage only defines configuration and contracts. It does not execute
# Google OAuth, call Google APIs, or store tokens.
GOOGLE_OAUTH_ENABLED=False
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.invalid/api/v1/google/oauth/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=https://app.example.invalid/settings/accounts?gmail=connected
GOOGLE_OAUTH_ERROR_REDIRECT_URL=https://app.example.invalid/settings/accounts?gmail=error
# Pydantic-settings expects complex values as JSON when set through env vars.
GOOGLE_OAUTH_FRONTEND_REDIRECT_ALLOWLIST=["https://app.example.invalid/settings/accounts?gmail=connected","https://app.example.invalid/settings/accounts?gmail=error"]
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
